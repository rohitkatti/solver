{
    "version": 6,
    "configurePresets": [
        {
            "name": "Debug",
            "displayName": "Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_PREFIX_PATH": "/opt/homebrew",
                "PostgreSQL_ROOT": "/opt/homebrew/opt/postgresql@18",
                "PostgreSQL_INCLUDE_DIR": "/opt/homebrew/include/postgresql@18",
                "PostgreSQL_LIBRARY": "/opt/homebrew/lib/postgresql@18/libpq.dylib"
            }
        },
        {
            "name": "Release",
            "displayName": "Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_PREFIX_PATH": "/opt/homebrew",
                "PostgreSQL_ROOT": "/opt/homebrew/opt/postgresql@18",
                "PostgreSQL_INCLUDE_DIR": "/opt/homebrew/include/postgresql@18",
                "PostgreSQL_LIBRARY": "/opt/homebrew/lib/postgresql@18/libpq.dylib"
            }
        }
    ]
}